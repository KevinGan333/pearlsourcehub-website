# Resend API key (required)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Lead notification email (required)
LEAD_TO_EMAIL=hello@pearlsourcehub.com

# Sender email (required)
# Must be verified in Resend before production sending
LEAD_FROM_EMAIL=PearlSourceHub <noreply@pearlsourcehub.com>

# Site URL (used for redirects and email links)
NEXT_PUBLIC_SITE_URL=https://www.pearlsourcehub.com

# Supabase configuration (required for admin backend)
# Get these from your Supabase project dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxx

# Supabase service role key (server-side only, never expose to browser)
# Get this from Supabase dashboard > Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxx

# Admin access control — comma-separated list of allowed admin emails
ADMIN_ALLOWED_EMAILS=hello@pearlsourcehub.com
